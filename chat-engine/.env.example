# Chat Engine — environment variables
# Copy to .env and fill in your values.

# ── Provider ──────────────────────────────────────────────────
# Options: openrouter | anthropic | bedrock | local
CHAT_ENGINE_PROVIDER=openrouter

# ── Model override (optional — each provider has a sensible default) ──
# CHAT_ENGINE_MODEL=deepseek/deepseek-v3.2

# ── OpenRouter ────────────────────────────────────────────────
OPENROUTER_API_KEY=your-key-here

# ── Anthropic direct ──────────────────────────────────────────
# ANTHROPIC_API_KEY=your-key-here

# ── Local (LM Studio, Ollama, etc.) ───────────────────────────
# CHAT_ENGINE_LOCAL_BASE_URL=http://localhost:1234/v1

# ── Generation parameters ─────────────────────────────────────
# Max tokens the model may generate per turn.
# Keep above ~300 — Strands raises an unrecoverable error if the model hits this limit
# mid-generation (stop_reason: max_tokens). 400 is safe for 3-5 sentence dialogue.
# Raise to 600+ if using response_length: free or a verbose model.
# CHAT_ENGINE_MAX_TOKENS=400

# Sampling temperature. Lower = more focused, higher = more varied.
# CHAT_ENGINE_TEMPERATURE=0.85

# ── Context tuning ────────────────────────────────────────────
# Override history_window from the .md file without editing the scenario.
# Recommended: 10-12 for local models (4K–8K context), leave unset for remote.
# CHAT_ENGINE_HISTORY_WINDOW=12

# Warn at startup if estimated max prompt size exceeds this token count.
# Set to match your local model's context window.
# CHAT_ENGINE_CONTEXT_LIMIT=3500

# ── Profiles (copy the relevant block into your .env) ─────────
#
# LOCAL (e.g. gemma4, qwen, llama on LM Studio / llama.cpp):
#   CHAT_ENGINE_PROVIDER=local
#   CHAT_ENGINE_LOCAL_BASE_URL=http://localhost:1234/v1
#   CHAT_ENGINE_MODEL=your-loaded-model-name
#   CHAT_ENGINE_MAX_TOKENS=400
#   CHAT_ENGINE_TEMPERATURE=0.85
#   CHAT_ENGINE_HISTORY_WINDOW=12
#   CHAT_ENGINE_CONTEXT_LIMIT=3500
#
# OPENROUTER (remote, generous context — no history_window override needed):
#   CHAT_ENGINE_PROVIDER=openrouter
#   OPENROUTER_API_KEY=your-key
#   CHAT_ENGINE_MODEL=deepseek/deepseek-v3.2
#   CHAT_ENGINE_MAX_TOKENS=400
#   CHAT_ENGINE_TEMPERATURE=0.85
