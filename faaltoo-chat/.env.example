# Provider: local | openrouter
FAALTOO_PROVIDER=local

# Local server (LM Studio, llama.cpp, Ollama with OpenAI compat)
FAALTOO_LOCAL_BASE_URL=http://localhost:1234/v1
FAALTOO_MODEL=default

# Optional: separate vision model (defaults to FAALTOO_MODEL)
# FAALTOO_VISION_MODEL=llava-v1.6

# For cloud via OpenRouter
# FAALTOO_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# FAALTOO_MODEL=deepseek/deepseek-v3.2
