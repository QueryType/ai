# ── Provider ──────────────────────────────────────────────────────────────────
# local | openrouter
STORY_ENGINE_PROVIDER=local

# ── Local (LMStudio or llama.cpp) ─────────────────────────────────────────────
# LMStudio default port: 1234
# llama.cpp server default port: 8080
STORY_ENGINE_LOCAL_BASE_URL=http://localhost:1234/v1

# Override base URL for the game_master role only (optional)
# STORY_ENGINE_GAME_MASTER_BASE_URL=http://localhost:8080/v1

# Model name as shown in LMStudio, or "default" for llama.cpp
STORY_ENGINE_GAME_MASTER_MODEL=default

# ── OpenRouter ────────────────────────────────────────────────────────────────
# STORY_ENGINE_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# STORY_ENGINE_GAME_MASTER_MODEL=deepseek/deepseek-v3.2

# ── Vision ────────────────────────────────────────────────────────────────────
# Set to true/false to skip the automatic startup probe (optional)
# STORY_ENGINE_VISION_CAPABLE=true

# ── Optional: append to every system prompt (model-specific tokens) ───────────
# STORY_ENGINE_SYSTEM_SUFFIX=
